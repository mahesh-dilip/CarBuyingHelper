# ── Anthropic (Claude) ──────────────────────────────────────────────
# https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Exa (semantic web search) ───────────────────────────────────────
# https://exa.ai → Dashboard → API Keys
EXA_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ── DVLA Vehicle Enquiry Service (UK vehicle data) ──────────────────
# https://developer-portal.driver-vehicle-licensing.api.gov.uk
DVLA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Supabase (Postgres) ─────────────────────────────────────────────
# Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server-side only — never expose to the client
SUPABASE_SERVICE_ROLE_KEY=eyJxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
